# Azure OpenAI — required for the agentic loop.
#   https://foundry-resource-sweden-01.openai.azure.com/
# Auth is KEYLESS by default: leave AZURE_OPENAI_API_KEY blank and sign in with
# `az login` (uses DefaultAzureCredential). Only set a key for key-based auth.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>
# Embeddings deployment for rag-search hybrid retrieval + ZAVA ingestion.
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21

# Where skill folders live (relative to repo root). Defaults to ./skills
SKILLS_DIR=skills

# ── Engines ───────────────────────────────────────────────────────────────────
# Copilot SDK (copilot_sdk) authenticates as your logged-in Copilot user and runs
# on Copilot's hosted models — no Azure OpenAI needed. Pick one here (default
# gpt-5.4-mini). Requires: pip install github-copilot-sdk && python -m copilot
# download-runtime.
# COPILOT_SDK_MODEL=gpt-5.4-mini
#
# The two BYOM engines reuse the AZURE_OPENAI_* settings above to run the Copilot
# runtime on YOUR Azure OpenAI deployment instead of Copilot's models:
#   * copilot_sdk_byom  — Copilot runtime loop, your model
#   * agent_framework   — Agent Framework loop ▸ Copilot runtime (BYOM) ▸ your model
# Both still need a logged-in Copilot user (the runtime authenticates to GitHub to
# start) PLUS Azure OpenAI (keyless via `az login`). The deployment MUST be an
# o-series or gpt-5 family model — the Copilot SDK encrypts prompts, so gpt-5.4-mini
# works but gpt-4o fails ("Encrypted content is not supported"). BYOM uses the Azure
# Responses API with its own api_version (2025-04-01-preview), so
# AZURE_OPENAI_API_VERSION below is ignored by these engines (it's only used by the
# Stage 1 chat-completions loop). Requires: pip install agent-framework.

# ── Starter skills (web-grounding is wired to WebIQ, rag-search to AI Search) ──
# web-grounding — Microsoft WebIQ via the official `webiq` SDK. If WEBIQ_API_KEY
# is unset, WebIQ falls back to Entra ID (DefaultAzureCredential) — note that
# keyless requires the WebIQ resource (api.microsoft.ai) to be pre-authorized
# for your sign-in client; otherwise set an API key.
WEBIQ_API_KEY=
WEBIQ_BACKEND=sdk
WEBIQ_REGION=us
# WEBIQ_MAX_RESULTS=5
# WEBIQ_MAX_LENGTH=2000

# rag-search (Azure AI Search) — names match the avatar-forge repo so an existing
# index drops in. If AZURE_SEARCH_API_KEY is unset, falls back to Entra ID
# (needs the 'Search Index Data Reader' role on the search service).
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
SEARCH_INDEX_NAME=zava-benefits-index
# Semantic configuration name on the index (used for semantic ranking).
SEARCH_SEMANTIC_CONFIG=zava-semantic

# ── ZAVA index ingestion (scripts/index_zava.py) ────────────────────────────
# Builds the rag-search index from the committed data/zava/ corpus:
#   download -> extract (pluggable) -> page-aware chunk -> embed -> push.
# Run keyless: `az login`, then `python scripts/index_zava.py all`.
# Extractor for PDFs: content_understanding (default) | doc_intelligence | pypdf
EXTRACTOR=content_understanding
# Azure AI Content Understanding (GA, api-version 2025-11-01). Lives in the
# Foundry/AI-Services resource (*.services.ai.azure.com), separate from AOAI.
# Default analyzer is prebuilt-layout (markdown + tables, no completion model needed).
# Set CONTENT_UNDERSTANDING_ANALYZER=prebuilt-documentSearch only if you've registered
# a completion-model deployment on the resource (richer figure/summary enrichment).
CONTENT_UNDERSTANDING_ENDPOINT=https://<your-resource>.services.ai.azure.com/
CONTENT_UNDERSTANDING_API_VERSION=2025-11-01
# CONTENT_UNDERSTANDING_ANALYZER=prebuilt-layout
# Optional, only if EXTRACTOR=doc_intelligence (needs azure-ai-documentintelligence):
# DOC_INTELLIGENCE_ENDPOINT=https://<your-docintel>.cognitiveservices.azure.com/
