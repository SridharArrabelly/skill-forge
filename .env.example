# Azure OpenAI — required for the agentic loop.
#   https://foundry-resource-sweden-01.openai.azure.com/
# Auth is KEYLESS by default: leave AZURE_OPENAI_API_KEY blank and sign in with
# `az login` (uses DefaultAzureCredential). Only set a key for key-based auth.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# Where skill folders live (relative to repo root). Defaults to ./skills
SKILLS_DIR=skills

# ── Starter skills (stubbed for now — wire later) ───────────────────────────
# web-grounding — Microsoft WebIQ. Names match the webiq-playground repo so the
# real backend drops in cleanly. If WEBIQ_API_KEY is unset, WebIQ falls back to
# Entra ID (DefaultAzureCredential).
WEBIQ_API_KEY=
WEBIQ_BACKEND=sdk
# WEBIQ_MCP_ENDPOINT=https://api.microsoft.ai/v3/mcp

# rag-search (Azure AI Search) — names match the avatar-forge repo so an existing
# index drops in. If AZURE_SEARCH_API_KEY is unset, falls back to Entra ID.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
SEARCH_INDEX_NAME=
